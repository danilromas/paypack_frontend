{
  "manifest_version": 3,
  "name": "PayPack Marketplace",
  "version": "0.2.1",
  "description": "Import Facebook Marketplace listings into PayPack with one click.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_title": "PayPack Marketplace",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://paypack.uno/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/marketplace/*",
        "https://facebook.com/marketplace/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
